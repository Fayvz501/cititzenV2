# ─── Citizen Monitor Pro Config ───
PORT=3000
JWT_SECRET=change-this-to-random-secret-key-min-32-chars
NODE_ENV=production

# Telegram Bot (optional — leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Web Push VAPID keys (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@citizen.app

# AI Moderation (optional — uses built-in filter if empty)
# Supports any OpenAI-compatible endpoint
AI_MODERATION_URL=
AI_MODERATION_KEY=

# Weather API (optional — openweathermap.org free tier)
WEATHER_API_KEY=
